{
  "name": "lesicilien",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npx @opennextjs/cloudflare build --skipNextBuild && cp .open-next/worker.js .open-next/assets/_worker.js",
    "start": "next start",
    "pages:build": "next build && npx @opennextjs/cloudflare build && cp .open-next/worker.js .open-next/assets/_worker.js",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1",
    "@supabase/supabase-js": "^2.49.4",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^4.5.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
